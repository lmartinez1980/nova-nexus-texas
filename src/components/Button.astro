---
interface Props {
  href?: string;
  variant?: "primary" | "secondary";
  class?: string;
  type?: "button" | "submit" | "reset";
  target?: string;
  rel?: string;
}
const {
  href,
  variant = "primary",
  class: className = "",
  type = "button",
  target,
  rel,
} = Astro.props;

const cls = `nnt-btn ${variant === "primary" ? "nnt-btn-primary" : "nnt-btn-secondary"} ${className}`.trim();
---
{href ? (
  <a href={href} class={cls} target={target} rel={rel}>
    <slot />
  </a>
) : (
  <button type={type} class={cls}>
    <slot />
  </button>
)}
