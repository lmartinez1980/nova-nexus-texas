---
import BaseLayout from "../components/BaseLayout.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";
import SectionHeading from "../components/SectionHeading.astro";

const values = [
  {
    title: "Faith first",
    body: "Built on a foundation of faith. We do business the way we live — honestly, respectfully, with our word as our bond.",
    icon: `<path d="M12 2v20"/><path d="M6 8h12"/>`,
  },
  {
    title: "Family always",
    body: "Family is why we show up. If we wouldn't build it for our own business, we won't ship it for yours.",
    icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2"/><circle cx="10" cy="7" r="4"/><path d="M21 21v-2a4 4 0 0 0-3-3.87"/>`,
  },
  {
    title: "Community rooted",
    body: "Arlington, Fort Worth, Dallas — our neighbors are our clients. We market like people we know are watching, because they are.",
    icon: `<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M9 22V12h6v10"/>`,
  },
  {
    title: "Honest by default",
    body: "Real prices. Real timelines. Real answers. When something isn't the right fit, we'll say so.",
    icon: `<path d="M20 6L9 17l-5-5"/>`,
  },
];
---
<BaseLayout
  title="About Nova Nexus Texas — Founder Story from Arlington, TX"
  description="Meet Lupe Martinez, founder of Nova Nexus Texas. 20+ years building brands, ships websites fast with AI, grounded in faith, family, and the Texas community."
>
  <!-- HERO -->
  <section class="relative pt-20 md:pt-28 pb-16 md:pb-20">
    <div class="max-w-4xl mx-auto px-5 md:px-8 text-center">
      <SectionHeading
        eyebrow="About"
        title="We're a Texas outfit building the future of small-business marketing."
        subtitle="Nova Nexus Texas started with one simple belief — the shop on Main Street deserves the same firepower as the chain down the road."
      />
    </div>
  </section>

  <!-- FOUNDER STORY -->
  <section class="relative py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-5 md:px-8">
      <div class="grid lg:grid-cols-5 gap-10 items-start">
        <div class="lg:col-span-2">
          <Card class="!p-6">
            <div class="relative rounded-xl overflow-hidden aspect-[4/5] bg-[color:var(--color-surface)]">
              <img src="/logo.jpg" alt="Nova Nexus Texas — Founder" class="h-full w-full object-cover" width="600" height="750" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>
              <div class="absolute bottom-5 left-5 right-5">
                <p class="text-white text-2xl font-semibold leading-tight">Lupe Martinez</p>
                <p class="text-[color:var(--color-muted)] text-sm mt-1">Founder & Principal · Arlington, Texas</p>
              </div>
            </div>
            <div class="mt-5 grid grid-cols-2 gap-4 text-center">
              <div>
                <p class="text-3xl font-bold nnt-gradient-text">20+</p>
                <p class="text-xs uppercase tracking-[0.15em] text-[color:var(--color-muted)] mt-1">Years experience</p>
              </div>
              <div>
                <p class="text-3xl font-bold nnt-gradient-text-warm">1</p>
                <p class="text-xs uppercase tracking-[0.15em] text-[color:var(--color-muted)] mt-1">Phone number</p>
              </div>
            </div>
          </Card>
        </div>

        <div class="lg:col-span-3 space-y-6 text-lg leading-relaxed text-[color:var(--color-text)]">
          <p>
            Lupe Martinez has spent two decades in technology and marketing — from big-company software rooms to helping local shops fix their Google listings on Saturday mornings. Along the way he noticed something: the same tools the Fortune 500 uses to dominate are now affordable enough for the bakery, the landscaper, the dentist, the church.
          </p>
          <p>
            <span class="text-white font-semibold">Nova Nexus Texas was built to close that gap.</span>
            With AI doing the heavy lifting on the tedious parts, Lupe can spend the time where it actually matters — understanding your business, your customers, and the neighborhood you serve.
          </p>
          <p>
            This isn't a side hustle. It's a calling. Faith-driven, family-first, and grounded in the Arlington community that raised three Martinez kids (Mila, Zachary, and Levi — ask about them, you'll hear about them).
          </p>
          <p class="text-[color:var(--color-muted)] italic border-l-2 border-[color:var(--color-cyan)] pl-5">
            “If we do right by the people in our community, the business takes care of itself. That's the whole plan.”
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- MISSION -->
  <section class="relative py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-5 md:px-8">
      <Card class="relative overflow-hidden !p-10 md:!p-14 text-center">
        <div class="absolute inset-0 bg-gradient-to-br from-[color:var(--color-violet)]/10 via-transparent to-[color:var(--color-cyan)]/10 pointer-events-none"></div>
        <div class="relative">
          <p class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-muted)]">Our mission</p>
          <h2 class="mt-4 text-3xl md:text-5xl font-bold text-white leading-tight">
            Give every local business a <span class="nnt-gradient-text">fighting chance online.</span>
          </h2>
          <p class="mt-6 max-w-2xl mx-auto text-lg text-[color:var(--color-muted)]">
            Not flashy jargon. Not templates pretending to be strategy. Real websites, real brands, real visibility — priced so the family-owned shop can actually afford them.
          </p>
        </div>
      </Card>
    </div>
  </section>

  <!-- VALUES -->
  <section class="relative py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-5 md:px-8">
      <SectionHeading
        eyebrow="What we stand for"
        title="Four things we won't compromise on."
      />
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mt-14">
        {values.map((v) => (
          <Card>
            <div class="h-11 w-11 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-[color:var(--color-amber)]">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" set:html={v.icon}></svg>
            </div>
            <h3 class="mt-5 text-lg font-semibold text-white">{v.title}</h3>
            <p class="mt-2 text-[color:var(--color-muted)] leading-relaxed text-sm">{v.body}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-5 md:px-8 text-center">
      <h2 class="text-3xl md:text-5xl font-bold text-white">Ready to talk?</h2>
      <p class="mt-5 text-lg text-[color:var(--color-muted)]">
        The discovery call is free. The conversation might be worth more than you think.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row justify-center gap-4">
        <Button href="/contact" variant="primary">Book Free Discovery</Button>
        <Button href="/services" variant="secondary">See What We Do</Button>
      </div>
    </div>
  </section>
</BaseLayout>
