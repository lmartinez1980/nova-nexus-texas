---
import BaseLayout from "../components/BaseLayout.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";
import SectionHeading from "../components/SectionHeading.astro";

/*
  Form handling:
  - Uses Formspree. Sign up at formspree.io, create a form, paste the ID below.
  - Until configured, form falls back to a mailto: link so nothing ever errors.
*/
const FORMSPREE_ID = ""; // e.g. "xyzabcde" from https://formspree.io/f/xyzabcde
const formAction = FORMSPREE_ID
  ? `https://formspree.io/f/${FORMSPREE_ID}`
  : "mailto:lupe@novanexustexas.com";
const formMethod = FORMSPREE_ID ? "POST" : "POST";
const formEnc = FORMSPREE_ID ? undefined : "text/plain";
---
<BaseLayout
  title="Contact Nova Nexus Texas — Book Your Free Discovery Call"
  description="Ready to talk? Book a free 30-minute discovery session with Nova Nexus Texas or email Lupe directly. Arlington, TX."
>
  <!-- HERO -->
  <section class="relative pt-20 md:pt-28 pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto px-5 md:px-8 text-center">
      <SectionHeading
        eyebrow="Contact"
        title="Let's talk. Thirty minutes. On the house."
        subtitle="No script, no sales pitch. Tell us about your business and we'll tell you honestly whether we can help."
      />
    </div>
  </section>

  <!-- Contact grid -->
  <section class="relative py-12 md:py-16">
    <div class="max-w-6xl mx-auto px-5 md:px-8">
      <div class="grid lg:grid-cols-5 gap-8">
        <!-- Primary CTA card -->
        <div class="lg:col-span-2">
          <Card class="relative overflow-hidden !p-8 md:!p-10 h-full">
            <div class="absolute inset-0 bg-gradient-to-br from-[color:var(--color-cyan)]/10 via-transparent to-[color:var(--color-magenta)]/10 pointer-events-none"></div>
            <div class="relative">
              <p class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-muted)]">Fastest path</p>
              <h2 class="mt-3 text-3xl md:text-4xl font-bold text-white leading-tight">
                Book the free <span class="nnt-gradient-text">Discovery Session.</span>
              </h2>
              <p class="mt-5 text-[color:var(--color-muted)] leading-relaxed">
                30 minutes. Phone, Zoom, or coffee in Arlington — your call. You'll leave with a plan whether you hire us or not.
              </p>
              <div class="mt-7">
                <Button href="mailto:lupe@novanexustexas.com?subject=Discovery%20Session" variant="primary" class="w-full">
                  Book Free Discovery
                </Button>
              </div>

              <div class="mt-10 space-y-5 text-sm">
                <div class="flex items-start gap-3">
                  <span class="h-9 w-9 flex-shrink-0 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-[color:var(--color-cyan)]">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                  </span>
                  <div>
                    <p class="text-[color:var(--color-muted)] text-xs uppercase tracking-[0.15em]">Email</p>
                    <a href="mailto:lupe@novanexustexas.com" class="text-white hover:text-[color:var(--color-cyan)] transition font-medium">lupe@novanexustexas.com</a>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <span class="h-9 w-9 flex-shrink-0 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-[color:var(--color-amber)]">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><path d="M12 22s7-7.5 7-12a7 7 0 1 0-14 0c0 4.5 7 12 7 12z"/><circle cx="12" cy="10" r="3"/></svg>
                  </span>
                  <div>
                    <p class="text-[color:var(--color-muted)] text-xs uppercase tracking-[0.15em]">Based in</p>
                    <p class="text-white font-medium">Arlington, Texas · Central Time</p>
                  </div>
                </div>
                <div class="flex items-start gap-3">
                  <span class="h-9 w-9 flex-shrink-0 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-[color:var(--color-magenta)]">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  </span>
                  <div>
                    <p class="text-[color:var(--color-muted)] text-xs uppercase tracking-[0.15em]">Hours</p>
                    <p class="text-white font-medium">Mon – Fri · 8a – 6p CT</p>
                  </div>
                </div>
              </div>

              <div class="mt-10 pt-6 border-t border-white/5">
                <p class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-muted)] mb-3">Social</p>
                <div class="flex gap-3">
                  <a href="#" aria-label="Facebook" class="h-10 w-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-[color:var(--color-muted)] hover:text-white hover:border-[color:var(--color-cyan)]/60 transition">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"/></svg>
                  </a>
                  <a href="#" aria-label="Instagram" class="h-10 w-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-[color:var(--color-muted)] hover:text-white hover:border-[color:var(--color-magenta)]/60 transition">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                  </a>
                  <a href="#" aria-label="LinkedIn" class="h-10 w-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-[color:var(--color-muted)] hover:text-white hover:border-[color:var(--color-royal)]/80 transition">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.95v5.66H9.35V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.26 2.37 4.26 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45z"/></svg>
                  </a>
                  <a href="#" aria-label="X (Twitter)" class="h-10 w-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-[color:var(--color-muted)] hover:text-white hover:border-[color:var(--color-cyan)]/60 transition">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                  </a>
                </div>
                <p class="mt-3 text-xs text-[color:var(--color-muted)]">Social channels coming online soon.</p>
              </div>
            </div>
          </Card>
        </div>

        <!-- Contact form -->
        <div class="lg:col-span-3">
          <Card class="!p-8 md:!p-10">
            <h2 class="text-2xl md:text-3xl font-bold text-white">Or send a quick note.</h2>
            <p class="mt-3 text-[color:var(--color-muted)]">
              Tell us a bit about your business. We'll reply within one business day — usually much sooner.
            </p>

            <form
              name="nnt-contact"
              method={formMethod}
              action={formAction}
              enctype={formEnc}
              class="mt-8 grid gap-5"
            >
              <input type="hidden" name="_subject" value="Nova Nexus Texas — new message" />
              <input type="hidden" name="_next" value="/thanks" />
              <p class="hidden" aria-hidden="true">
                <label>Leave this field empty: <input name="_gotcha" tabindex="-1" autocomplete="off" /></label>
              </p>

              <div class="grid md:grid-cols-2 gap-5">
                <label class="block">
                  <span class="text-sm font-medium text-[color:var(--color-muted)]">Your name</span>
                  <input
                    type="text"
                    name="name"
                    required
                    autocomplete="name"
                    class="mt-2 block w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-white placeholder:text-[color:var(--color-muted)] focus:outline-none focus:border-[color:var(--color-cyan)] focus:ring-2 focus:ring-[color:var(--color-cyan)]/30 transition"
                    placeholder="Jane Doe"
                  />
                </label>
                <label class="block">
                  <span class="text-sm font-medium text-[color:var(--color-muted)]">Email</span>
                  <input
                    type="email"
                    name="email"
                    required
                    autocomplete="email"
                    class="mt-2 block w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-white placeholder:text-[color:var(--color-muted)] focus:outline-none focus:border-[color:var(--color-cyan)] focus:ring-2 focus:ring-[color:var(--color-cyan)]/30 transition"
                    placeholder="you@business.com"
                  />
                </label>
              </div>

              <div class="grid md:grid-cols-2 gap-5">
                <label class="block">
                  <span class="text-sm font-medium text-[color:var(--color-muted)]">Business name</span>
                  <input
                    type="text"
                    name="business"
                    class="mt-2 block w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-white placeholder:text-[color:var(--color-muted)] focus:outline-none focus:border-[color:var(--color-cyan)] focus:ring-2 focus:ring-[color:var(--color-cyan)]/30 transition"
                    placeholder="Jane's Bakery"
                  />
                </label>
                <label class="block">
                  <span class="text-sm font-medium text-[color:var(--color-muted)]">I'm interested in</span>
                  <select
                    name="interest"
                    class="nnt-select mt-2 block w-full rounded-xl border border-white/10 bg-[#0a0e1a] px-4 py-3 text-white focus:outline-none focus:border-[color:var(--color-cyan)] focus:ring-2 focus:ring-[color:var(--color-cyan)]/30 transition appearance-none cursor-pointer"
                    style="background-image: url(&quot;data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%2325D6F7' stroke-width='2' stroke-linecap='round'%3e%3cpolyline points='6 9 12 15 18 9'/%3e%3c/svg%3e&quot;); background-repeat: no-repeat; background-position: right 1rem center; background-size: 1rem;"
                  >
                    <option value="">Choose one…</option>
                    <option value="New website">New website</option>
                    <option value="Starter ($600)">Starter package ($600)</option>
                    <option value="Community Focus ($1,200)">Community Focus ($1,200)</option>
                    <option value="Ambassador ($2,500)">Ambassador ($2,500)</option>
                    <option value="Branding / rebrand">Branding / rebrand</option>
                    <option value="Local SEO">Local SEO</option>
                    <option value="AI content help">AI content help</option>
                    <option value="Just exploring">Just exploring</option>
                  </select>
                </label>
              </div>

              <label class="block">
                <span class="text-sm font-medium text-[color:var(--color-muted)]">Tell us a bit about your business</span>
                <textarea
                  name="message"
                  rows="5"
                  required
                  class="mt-2 block w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-white placeholder:text-[color:var(--color-muted)] focus:outline-none focus:border-[color:var(--color-cyan)] focus:ring-2 focus:ring-[color:var(--color-cyan)]/30 transition"
                  placeholder="What do you do? What's working, what's not, and what would a win look like?"
                ></textarea>
              </label>

              <div class="flex flex-col sm:flex-row items-center gap-4 pt-2">
                <Button type="submit" variant="primary" class="w-full sm:w-auto">
                  Send Message
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                </Button>
                <p class="text-xs text-[color:var(--color-muted)]">
                  By sending, you agree we can email you back. That's it. No newsletter, no spam.
                </p>
              </div>
            </form>
          </Card>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
