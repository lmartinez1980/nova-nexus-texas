---
import BaseLayout from "../components/BaseLayout.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";
import SectionHeading from "../components/SectionHeading.astro";

const services = [
  {
    name: "Web Design & Development",
    tagline: "Sites that look sharp, load fast, and sell.",
    accent: "cyan",
    tiers: [
      {
        name: "Starter",
        price: "$600-$1,200",
        bestFor: "Simple online presence",
        features: [
          "3-5 pages",
          "Template-based with custom branding",
          "Mobile responsive",
          "Basic SEO setup",
          "Contact form",
          "Google Maps integration",
          "2 rounds of revisions",
        ],
        delivery: "2-3 weeks",
      },
      {
        name: "Business",
        price: "$1,500-$3,000",
        bestFor: "Professional services, lead generation",
        features: [
          "5-10 pages",
          "Custom design tailored to brand",
          "Advanced SEO optimization",
          "Blog/news section",
          "Photo galleries",
          "Booking integration options",
          "Google Business Profile optimization",
          "3 rounds of revisions",
        ],
        delivery: "3-4 weeks",
        featured: true,
      },
      {
        name: "Pro",
        price: "$3,500-$6,000",
        bestFor: "E-commerce, complex functionality",
        features: [
          "10+ pages",
          "Fully custom design & development",
          "E-commerce capabilities",
          "Advanced integrations (CRM, email, etc.)",
          "Custom forms and functionality",
          "Performance optimization",
          "Security hardening",
          "Training session included",
          "4 rounds of revisions",
        ],
        delivery: "4-6 weeks",
      },
    ],
  },
  {
    name: "Branding & Identity",
    tagline: "A look that earns a second glance.",
    accent: "magenta",
    tiers: [
      {
        name: "Logo Only",
        price: "$400-$800",
        bestFor: "Just need the logo",
        features: [
          "3 initial logo concepts",
          "3 rounds of revisions",
          "Final files (PNG, JPG, SVG, EPS)",
          "Black/white/color versions",
          "Social media sizes",
          "Basic usage guidelines",
        ],
        delivery: "1-2 weeks",
      },
      {
        name: "Core Brand",
        price: "$1,200-$2,500",
        bestFor: "Complete visual identity",
        features: [
          "Everything in Logo Only",
          "Color palette (primary + secondary)",
          "Typography system (2-3 fonts)",
          "Brand style guide (10-15 pages)",
          "Business card design",
          "Letterhead template",
          "Email signature template",
        ],
        delivery: "2-3 weeks",
        featured: true,
      },
      {
        name: "Full Identity",
        price: "$3,000-$5,000",
        bestFor: "Everything you need",
        features: [
          "Everything in Core Brand",
          "Brand voice & messaging framework",
          "Tagline development",
          "Extended style guide (20-30 pages)",
          "Social media templates (5-10 designs)",
          "Brand pattern/texture library",
          "Photography direction & mood boards",
          "Brand story & positioning statement",
          "Presentation template",
        ],
        delivery: "4-5 weeks",
      },
    ],
  },
  {
    name: "Business Consulting",
    tagline: "Strategy that moves the needle.",
    accent: "violet",
    tiers: [
      {
        name: "Hourly",
        price: "$125-$175/hr",
        bestFor: "Flexible as-needed help",
        features: [
          "Marketing strategy",
          "Business planning",
          "Technology recommendations",
          "Operational efficiency review",
          "Minimum 2-hour booking",
        ],
        delivery: "On-demand",
      },
      {
        name: "Strategy Session",
        price: "$300-$500",
        bestFor: "Intensive deep dive",
        features: [
          "2-3 hour working session",
          "Pre-session questionnaire & research",
          "Focus area of your choice",
          "Written summary & action plan",
          "1 follow-up call (30 minutes) included",
        ],
        delivery: "Plan delivered in 3 days",
        featured: true,
      },
      {
        name: "Monthly Retainer",
        price: "$800-$1,500/mo",
        bestFor: "Ongoing partnership",
        features: [
          "4-6 hours of advisory time per month",
          "Email & text support (24hr response)",
          "Monthly strategic planning call",
          "Quarterly deep-dive review",
          "Priority scheduling",
          "Discounted rates on project work",
          "Month-to-month (no long-term contract)",
        ],
        delivery: "Ongoing",
      },
    ],
  },
];

const bundles = [
  {
    name: "Website + Branding",
    discount: "15%",
    description: "Get a cohesive online presence — your new brand identity built directly into a custom website.",
    includes: [
      "Custom website (your tier)",
      "Brand package (your tier)",
      "Seamless integration",
      "One unified timeline",
    ],
    example: "Business Site ($2,000) + Core Brand ($1,500) = $3,500 → $2,975",
  },
  {
    name: "Complete Launch Package",
    discount: "20%",
    description: "Everything you need to launch or relaunch: brand, website, and strategic guidance.",
    includes: [
      "Website build",
      "Brand identity",
      "3-month consulting retainer",
      "Launch strategy & support",
    ],
    example: "Business Site + Core Brand + 3-Month Retainer = $5,900 → $4,720",
  },
];

const faqs = [
  {
    q: "What is the free discovery session?",
    a: "A no-pressure 30-minute call — phone, Zoom, or coffee if you're in Arlington. We listen, ask smart questions, and send you a written summary with our honest recommendation. You're under no obligation to hire us. Plenty of people walk away with a plan and go build it themselves, and that's fine.",
  },
  {
    q: "Is that really the whole price?",
    a: "Yes. Every tier is a flat project fee with the scope spelled out before you pay a dime. The only things that ever add cost are items you specifically request outside the scope — and we quote them upfront, too. Honest pricing. No smoke. No mirrors.",
  },
  {
    q: "Why Nova Nexus Texas instead of a big agency?",
    a: "Twenty years of real experience. One founder who picks up the phone. AI-assisted workflows that cut the cost without cutting the quality. And a deep-rooted belief that local businesses deserve the same firepower as the big guys.",
  },
  {
    q: "Can I mix and match tiers?",
    a: "Absolutely. Want a Pro website with a Logo Only branding package? No problem. We'll build a custom quote that fits your needs.",
  },
  {
    q: "Do you offer payment plans?",
    a: "Yes! For projects over $2,000, we typically do 50% deposit upfront and 50% on delivery. Custom payment plans available on request.",
  },
  {
    q: "How fast can you launch?",
    a: "Website Starter sites: 2-3 weeks. Branding Logo Only: 1-2 weeks. Most projects deliver within 3-4 weeks. We move fast because AI handles the grunt work, not because we're cutting corners.",
  },
  {
    q: "Do you work with businesses outside of Arlington?",
    a: "Absolutely. We're Arlington-based but serve the whole DFW Metroplex and clients anywhere in Texas. A lot of the work happens remote-first — the magic is the discovery conversation and the ongoing communication, not a zip code.",
  },
];

const accentColors: Record<string, string> = {
  cyan: "var(--color-cyan)",
  magenta: "var(--color-magenta)",
  violet: "var(--color-violet)",
  amber: "var(--color-amber)",
};
---
<BaseLayout
  title="Pricing — Transparent Pricing for Web, Branding & Consulting · Nova Nexus Texas"
  description="Clear pricing for all services. Web design $600-$6,000. Branding $400-$5,000. Consulting $125/hr-$1,500/mo. Bundle discounts available. No hidden fees."
>
  <!-- HERO -->
  <section class="relative pt-20 md:pt-28 pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto px-5 md:px-8 text-center">
      <SectionHeading
        eyebrow="Pricing"
        title="Honest pricing. No smoke. No mirrors."
        subtitle="Three services. Clear tiers. Every deliverable written down before you sign anything."
      />
    </div>
  </section>

  <!-- SERVICES WITH TIERS -->
  {services.map((service, sIdx) => (
    <section class={`relative py-16 md:py-20 ${sIdx % 2 === 1 ? 'bg-white/[0.02]' : ''}`}>
      <div class="max-w-7xl mx-auto px-5 md:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-white">{service.name}</h2>
          <p class={`mt-2 text-lg`} style={`color: ${accentColors[service.accent]}`}>{service.tagline}</p>
        </div>

        <div class="grid md:grid-cols-3 gap-6 items-start">
          {service.tiers.map((tier) => (
            <div class={`relative flex ${tier.featured ? "md:-my-4" : ""}`}>
              {tier.featured && (
                <div class="absolute -top-4 left-1/2 -translate-x-1/2 z-10">
                  <span class="inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-xs font-bold uppercase tracking-[0.18em] text-white shadow-[0_8px_24px_-8px_rgba(123,44,242,0.6)]" style="background-image: linear-gradient(135deg, #25D6F7 0%, #7B2CF2 50%, #E83BAA 100%);">
                    Most Popular
                  </span>
                </div>
              )}
              <Card class={`relative flex flex-col w-full ${tier.featured ? "!p-8 ring-1 ring-white/10 shadow-[0_20px_60px_-20px_rgba(123,44,242,0.3)]" : ""}`}>
                {tier.featured && (
                  <div class="absolute inset-0 pointer-events-none rounded-[inherit] bg-gradient-to-br from-white/5 via-transparent to-white/5"></div>
                )}
                <div class="relative flex-1 flex flex-col">
                  <div>
                    <h3 class="text-2xl font-bold text-white">{tier.name}</h3>
                    <p class={`mt-3 text-3xl font-bold`} style={`color: ${accentColors[service.accent]}`}>{tier.price}</p>
                    <p class="mt-2 text-sm text-[color:var(--color-muted)] italic">{tier.bestFor}</p>
                  </div>

                  <ul class="mt-6 space-y-2.5 flex-1">
                    {tier.features.map((f) => (
                      <li class="flex items-start gap-2.5 text-sm">
                        <span class="mt-[2px] inline-flex h-4 w-4 flex-shrink-0 items-center justify-center rounded-full bg-white/5 text-[color:var(--color-cyan)]">
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="h-2.5 w-2.5"><polyline points="20 6 9 17 4 12"/></svg>
                        </span>
                        <span class="text-[color:var(--color-text)]">{f}</span>
                      </li>
                    ))}
                  </ul>

                  <div class="mt-6">
                    <p class={`text-sm font-semibold`} style={`color: ${accentColors[service.accent]}`}>⏱ {tier.delivery}</p>
                  </div>
                </div>
              </Card>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- BUNDLES -->
  <section class="relative py-20 md:py-28 bg-gradient-to-br from-[color:var(--color-royal)]/10 to-[color:var(--color-cyan)]/10">
    <div class="max-w-7xl mx-auto px-5 md:px-8">
      <SectionHeading
        eyebrow="Save with Bundles"
        title="Combine services and save"
        subtitle="Bundle any two or three services together for instant savings."
      />

      <div class="grid md:grid-cols-2 gap-8 mt-14 max-w-5xl mx-auto">
        {bundles.map((bundle) => (
          <Card>
            <div class="flex items-start justify-between mb-4">
              <h3 class="text-2xl font-bold text-white">{bundle.name}</h3>
              <span class="inline-block px-3 py-1 text-sm font-semibold bg-green-500/20 text-green-400 rounded-full">Save {bundle.discount}</span>
            </div>
            <p class="text-[color:var(--color-muted)] mb-6">{bundle.description}</p>
            <ul class="space-y-2.5 mb-6">
              {bundle.includes.map((item) => (
                <li class="flex items-start gap-3 text-sm">
                  <span class="text-[color:var(--color-cyan)]">+</span>
                  <span class="text-[color:var(--color-text)]">{item}</span>
                </li>
              ))}
            </ul>
            <div class="bg-white/5 p-4 rounded-lg">
              <p class="text-sm text-[color:var(--color-muted)] mb-1">Example:</p>
              <p class="text-sm">{bundle.example.split(' → ')[0]} = <span class="line-through opacity-60">{bundle.example.match(/\$\d+,?\d+/g)?.[2]}</span> → <span class="text-[color:var(--color-cyan)] font-bold text-lg">{bundle.example.split(' → ')[1]}</span></p>
            </div>
          </Card>
        ))}
      </div>

      <div class="mt-12 text-center">
        <Button href="/contact" variant="primary">Request Custom Bundle Quote</Button>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="relative py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-5 md:px-8">
      <SectionHeading
        eyebrow="FAQ"
        title="Questions we get a lot."
      />

      <div class="mt-12 space-y-3">
        {faqs.map((f, i) => (
          <details class="nnt-faq nnt-card !p-0 group" open={i === 0}>
            <summary class="flex items-center justify-between gap-4 px-6 py-5 md:px-8 md:py-6 cursor-pointer">
              <span class="text-lg md:text-xl font-semibold text-white">{f.q}</span>
              <span class="nnt-faq-chev flex-shrink-0 text-[color:var(--color-cyan)]">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><polyline points="6 9 12 15 18 9"/></svg>
              </span>
            </summary>
            <div class="px-6 pb-6 md:px-8 md:pb-7 text-[color:var(--color-muted)] leading-relaxed">
              {f.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-5 md:px-8 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white">Still on the fence?</h2>
      <p class="mt-5 text-lg text-[color:var(--color-muted)]">
        The discovery call is free. It's 30 minutes. You'll know right away if we're the right fit.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row justify-center gap-4">
        <Button href="/contact" variant="primary">Book Free Discovery</Button>
        <Button href="mailto:lupe@novanexustexas.com" variant="secondary">Email First</Button>
      </div>
    </div>
  </section>
</BaseLayout>
