---
import BaseLayout from "../components/BaseLayout.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";
import SectionHeading from "../components/SectionHeading.astro";

const tiers = [
  {
    name: "Starter",
    subtitle: "Essentials",
    price: "$600",
    priceNote: "from",
    blurb: "Get a real website online. Fast. Clean. Clearly yours.",
    features: [
      "3-page website (Home · About · Contact)",
      "Mobile-first responsive design",
      "Basic on-page SEO setup",
      "Contact form + email delivery",
      "Google Business Profile basics",
      "30-day post-launch support",
    ],
    cta: "Start with Essentials",
    featured: false,
  },
  {
    name: "Community Focus",
    subtitle: "Most popular",
    price: "$1,200",
    priceNote: null,
    blurb: "The sweet spot for most local businesses. Everything to get found and booked.",
    features: [
      "Up to 6 pages, custom-designed",
      "Full brand setup (logo, colors, type)",
      "Local SEO + Google Business tune-up",
      "Booking or scheduling integration",
      "1 launch blog post (AI-drafted, human-polished)",
      "Social media starter templates",
      "60-day post-launch support",
    ],
    cta: "Choose Community Focus",
    featured: true,
  },
  {
    name: "Ambassador",
    subtitle: "Full partnership",
    price: "$2,500",
    priceNote: null,
    blurb: "We act like part of your team. Built for businesses ready to scale.",
    features: [
      "Unlimited pages (within reason)",
      "Full branding system + style guide",
      "AI-assisted content pipeline",
      "Booking + CRM wire-up",
      "Local community campaign (launch)",
      "Monthly performance report",
      "90-day post-launch support",
    ],
    cta: "Go Ambassador",
    featured: false,
  },
];

const faqs = [
  {
    q: "What is the free discovery session?",
    a: "A no-pressure 30-minute call — phone, Zoom, or coffee if you're in Arlington. We listen, ask smart questions, and send you a written summary with our honest recommendation. You're under no obligation to hire us. Plenty of people walk away with a plan and go build it themselves, and that's fine.",
  },
  {
    q: "Is that really the whole price?",
    a: "Yes. Every tier is a flat project fee with the scope spelled out before you pay a dime. The only things that ever add cost are items you specifically request outside the scope — and we quote them upfront, too. Honest pricing. No smoke. No mirrors.",
  },
  {
    q: "Why Nova Nexus Texas instead of a big agency?",
    a: "Twenty years of real experience. One founder who picks up the phone. AI-assisted workflows that cut the cost without cutting the quality. And a deep-rooted belief that local businesses deserve the same firepower as the big guys.",
  },
  {
    q: "What about ongoing costs like hosting or domains?",
    a: "Hosting on modern static platforms like Vercel or Netlify is free or near-free for most small-business sites. You'll own your domain and all your accounts. We don't hold anything hostage — if you ever leave us, you take everything with you.",
  },
  {
    q: "How fast can you launch?",
    a: "Starter sites typically go live in 1–2 weeks. Community Focus is 3–4 weeks. Ambassador runs 4–6 weeks depending on scope. We move fast because AI handles the grunt work, not because we're cutting corners.",
  },
  {
    q: "Do you work with businesses outside of Arlington?",
    a: "Absolutely. We're Arlington-based but serve the whole DFW Metroplex and clients anywhere in Texas. A lot of the work happens remote-first — the magic is the discovery conversation and the ongoing communication, not a zip code.",
  },
];
---
<BaseLayout
  title="Pricing — Honest Flat-Fee Website & Marketing Packages · Nova Nexus Texas"
  description="Three clear pricing tiers for Texas small businesses. From $600 Starter websites to $2,500 full Ambassador partnerships. No hidden fees, no surprises."
>
  <!-- HERO -->
  <section class="relative pt-20 md:pt-28 pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto px-5 md:px-8 text-center">
      <SectionHeading
        eyebrow="Pricing"
        title="Honest pricing. No smoke. No mirrors."
        subtitle="Three tiers. Flat fees. Every deliverable written down before you sign anything."
      />
    </div>
  </section>

  <!-- TIERS -->
  <section class="relative py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-5 md:px-8">
      <div class="grid md:grid-cols-3 gap-6 items-stretch">
        {tiers.map((t) => (
          <div class={`relative flex ${t.featured ? "md:-my-6" : ""}`}>
            {t.featured && (
              <div class="absolute -top-4 left-1/2 -translate-x-1/2 z-10">
                <span class="inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-xs font-bold uppercase tracking-[0.18em] text-white shadow-[0_8px_24px_-8px_rgba(232,59,170,0.6)]" style="background-image: linear-gradient(135deg, #25D6F7 0%, #7B2CF2 50%, #E83BAA 100%);">
                  {t.subtitle}
                </span>
              </div>
            )}
            <Card class={`relative flex flex-col w-full ${t.featured ? "!p-10 ring-1 ring-[color:var(--color-violet)]/50 shadow-[0_20px_60px_-20px_rgba(123,44,242,0.5)]" : ""}`}>
              {t.featured && (
                <div class="absolute inset-0 pointer-events-none rounded-[inherit] bg-gradient-to-br from-[color:var(--color-cyan)]/8 via-transparent to-[color:var(--color-magenta)]/10"></div>
              )}
              <div class="relative flex-1 flex flex-col">
                <div>
                  {!t.featured && (
                    <p class="text-xs uppercase tracking-[0.2em] text-[color:var(--color-muted)]">{t.subtitle}</p>
                  )}
                  <h3 class={`mt-${t.featured ? "2" : "1"} text-2xl md:text-3xl font-bold text-white`}>{t.name}</h3>
                  <div class="mt-5 flex items-baseline gap-2">
                    {t.priceNote && <span class="text-sm text-[color:var(--color-muted)]">{t.priceNote}</span>}
                    <span class={`text-5xl md:text-6xl font-bold ${t.featured ? "nnt-gradient-text" : "text-white"}`}>{t.price}</span>
                  </div>
                  <p class="mt-4 text-[color:var(--color-muted)] leading-relaxed">{t.blurb}</p>
                </div>

                <ul class="mt-7 space-y-3 flex-1">
                  {t.features.map((f) => (
                    <li class="flex items-start gap-3 text-sm">
                      <span class="mt-[2px] inline-flex h-4 w-4 flex-shrink-0 items-center justify-center rounded-full bg-[color:var(--color-cyan)]/15 text-[color:var(--color-cyan)]">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="h-2.5 w-2.5"><polyline points="20 6 9 17 4 12"/></svg>
                      </span>
                      <span class="text-[color:var(--color-text)]">{f}</span>
                    </li>
                  ))}
                </ul>

                <div class="mt-8">
                  <Button href="/contact" variant={t.featured ? "primary" : "secondary"} class="w-full">
                    {t.cta}
                  </Button>
                </div>
              </div>
            </Card>
          </div>
        ))}
      </div>

      <p class="mt-10 text-center text-sm text-[color:var(--color-muted)]">
        Prices in USD. One-time project fees. No retainers, no subscriptions, no surprise bills.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="relative py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-5 md:px-8">
      <SectionHeading
        eyebrow="FAQ"
        title="Questions we get a lot."
      />

      <div class="mt-12 space-y-3">
        {faqs.map((f, i) => (
          <details class="nnt-faq nnt-card !p-0 group" open={i === 0}>
            <summary class="flex items-center justify-between gap-4 px-6 py-5 md:px-8 md:py-6 cursor-pointer">
              <span class="text-lg md:text-xl font-semibold text-white">{f.q}</span>
              <span class="nnt-faq-chev flex-shrink-0 text-[color:var(--color-cyan)]">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><polyline points="6 9 12 15 18 9"/></svg>
              </span>
            </summary>
            <div class="px-6 pb-6 md:px-8 md:pb-7 text-[color:var(--color-muted)] leading-relaxed">
              {f.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-5 md:px-8 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white">Still on the fence?</h2>
      <p class="mt-5 text-lg text-[color:var(--color-muted)]">
        The discovery call is free. It's 30 minutes. You'll know right away if we're the right fit.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row justify-center gap-4">
        <Button href="/contact" variant="primary">Book Free Discovery</Button>
        <Button href="mailto:lupe@novanexustexas.com" variant="secondary">Email First</Button>
      </div>
    </div>
  </section>
</BaseLayout>
