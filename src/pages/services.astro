---
import BaseLayout from "../components/BaseLayout.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { services } from "../data/services";

const accentGlow: Record<string, string> = {
  cyan: "from-[color:var(--color-cyan)]/30 to-transparent",
  violet: "from-[color:var(--color-violet)]/30 to-transparent",
  magenta: "from-[color:var(--color-magenta)]/30 to-transparent",
  amber: "from-[color:var(--color-amber)]/30 to-transparent",
  royal: "from-[color:var(--color-royal)]/30 to-transparent",
};

const accentText: Record<string, string> = {
  cyan: "text-[color:var(--color-cyan)]",
  violet: "text-[color:var(--color-violet)]",
  magenta: "text-[color:var(--color-magenta)]",
  amber: "text-[color:var(--color-amber)]",
  royal: "text-[color:var(--color-cyan)]",
};

const accentBorder: Record<string, string> = {
  cyan: "border-[color:var(--color-cyan)]/20",
  violet: "border-[color:var(--color-violet)]/20",
  magenta: "border-[color:var(--color-magenta)]/20",
  amber: "border-[color:var(--color-amber)]/20",
  royal: "border-[color:var(--color-cyan)]/20",
};

const process = [
  { step: "01", title: "Discovery", body: "Free 30-minute call. We learn about your business, your customers, and what good looks like for you." },
  { step: "02", title: "Blueprint", body: "A written plan with scope, timeline, and a flat price. No mystery line items." },
  { step: "03", title: "Build", body: "We work fast using AI as the assistant — humans make every judgment call. You see drafts early." },
  { step: "04", title: "Launch & support", body: "We ship it, train you on it, and stick around. 30 to 90 days of support included on every tier." },
];

// Separate core services (with pricing) from supplemental services
const coreServices = services.filter(s => s.pricingTiers);
const supplementalServices = services.filter(s => !s.pricingTiers);
---
<BaseLayout
  title="Services — Web Design, Branding, Business Consulting · Nova Nexus Texas"
  description="Website development, branding & identity, and business consulting for Arlington and DFW businesses. Transparent pricing, AI-accelerated delivery, 20 years of experience."
>
  <!-- HERO -->
  <section class="relative pt-20 md:pt-28 pb-12 md:pb-16">
    <div class="max-w-4xl mx-auto px-5 md:px-8 text-center">
      <SectionHeading
        eyebrow="Services"
        title="Services Built for Main Street"
        subtitle="Website development, branding, and business consulting — designed to make local businesses stand out and succeed."
      />
    </div>
  </section>

  <!-- CORE SERVICES WITH PRICING -->
  {coreServices.map((service, idx) => (
    <section class={`relative py-16 md:py-24 ${idx % 2 === 1 ? 'bg-white/[0.02]' : ''}`}>
      <div class="max-w-7xl mx-auto px-5 md:px-8">
        <div class="flex items-start gap-5 mb-8">
          <div class={`h-14 w-14 flex-shrink-0 rounded-2xl border border-white/10 bg-gradient-to-br ${accentGlow[service.accent]} flex items-center justify-center text-white`}>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-7 w-7" set:html={service.iconSvg}></svg>
          </div>
          <div class="flex-1">
            <h2 class="text-3xl md:text-4xl font-bold text-white leading-tight">{service.title}</h2>
            <p class={`mt-1 text-lg ${accentText[service.accent]}`}>{service.tagline}</p>
          </div>
        </div>

        <p class="text-[color:var(--color-muted)] leading-relaxed text-lg mb-8 max-w-3xl">{service.description}</p>

        <div class="mb-8">
          <h3 class="text-white font-semibold mb-4">What's included:</h3>
          <div class="grid md:grid-cols-2 gap-3">
            {service.bullets.map((b) => (
              <div class="flex items-start gap-3 text-sm">
                <span class="mt-[2px] inline-flex h-4 w-4 flex-shrink-0 items-center justify-center rounded-full bg-white/5 border border-white/10 text-[color:var(--color-cyan)]">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="h-2.5 w-2.5"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                <span class="text-[color:var(--color-text)]">{b}</span>
              </div>
            ))}
          </div>
        </div>

        {service.pricingTiers && (
          <div>
            <h3 class="text-white font-semibold mb-6 text-xl">Pricing Tiers:</h3>
            <div class="grid md:grid-cols-3 gap-6">
              {service.pricingTiers.map((tier) => (
                <Card class={`group hover:border-${service.accent}/30 transition-all`}>
                  <h4 class="text-xl font-bold text-white">{tier.name}</h4>
                  <p class={`text-2xl font-bold mt-2 ${accentText[service.accent]}`}>{tier.priceRange}</p>
                  <p class="text-sm text-[color:var(--color-muted)] mt-1 italic">{tier.bestFor}</p>
                  
                  <ul class="mt-6 space-y-2.5">
                    {tier.features.map((f) => (
                      <li class="flex items-start gap-2 text-sm">
                        <span class="mt-[2px] inline-flex h-3 w-3 flex-shrink-0 items-center justify-center rounded-full bg-white/5 text-[color:var(--color-cyan)]">
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="h-2 w-2"><polyline points="20 6 9 17 4 12"/></svg>
                        </span>
                        <span class="text-[color:var(--color-text)]">{f}</span>
                      </li>
                    ))}
                  </ul>
                  
                  <p class={`mt-6 text-sm font-semibold ${accentText[service.accent]}`}>⏱ {tier.delivery}</p>
                </Card>
              ))}
            </div>
          </div>
        )}
      </div>
    </section>
  ))}

  <!-- BUNDLES -->
  <section class="relative py-20 md:py-28 bg-gradient-to-br from-[color:var(--color-royal)]/10 to-[color:var(--color-cyan)]/10">
    <div class="max-w-7xl mx-auto px-5 md:px-8">
      <SectionHeading
        eyebrow="Save with Bundles"
        title="Combine services and save"
        subtitle="More value, less guesswork."
      />

      <div class="grid md:grid-cols-2 gap-8 mt-14 max-w-5xl mx-auto">
        <Card>
          <div class="flex items-start justify-between mb-4">
            <h3 class="text-2xl font-bold text-white">Website + Branding</h3>
            <span class="inline-block px-3 py-1 text-sm font-semibold bg-green-500/20 text-green-400 rounded-full">Save 15%</span>
          </div>
          <p class="text-[color:var(--color-muted)] mb-6">Get a cohesive online presence — your new brand identity built directly into a custom website.</p>
          <ul class="space-y-2.5 mb-6">
            <li class="flex items-start gap-3 text-sm">
              <span class="text-[color:var(--color-cyan)]">+</span>
              <span class="text-[color:var(--color-text)]">Custom website (your tier)</span>
            </li>
            <li class="flex items-start gap-3 text-sm">
              <span class="text-[color:var(--color-cyan)]">+</span>
              <span class="text-[color:var(--color-text)]">Brand package (your tier)</span>
            </li>
            <li class="flex items-start gap-3 text-sm">
              <span class="text-[color:var(--color-cyan)]">+</span>
              <span class="text-[color:var(--color-text)]">Seamless integration</span>
            </li>
          </ul>
          <div class="bg-white/5 p-4 rounded-lg">
            <p class="text-sm text-[color:var(--color-muted)] mb-1">Example:</p>
            <p class="text-sm">Business Site ($2,000) + Core Brand ($1,500) = <span class="line-through opacity-60">$3,500</span> → <span class="text-[color:var(--color-cyan)] font-bold text-lg">$2,975</span></p>
          </div>
        </Card>

        <Card>
          <div class="flex items-start justify-between mb-4">
            <h3 class="text-2xl font-bold text-white">Complete Launch Package</h3>
            <span class="inline-block px-3 py-1 text-sm font-semibold bg-green-500/20 text-green-400 rounded-full">Save 20%</span>
          </div>
          <p class="text-[color:var(--color-muted)] mb-6">Everything you need to launch or relaunch your business: brand, website, and strategic guidance.</p>
          <ul class="space-y-2.5 mb-6">
            <li class="flex items-start gap-3 text-sm">
              <span class="text-[color:var(--color-cyan)]">+</span>
              <span class="text-[color:var(--color-text)]">Website build</span>
            </li>
            <li class="flex items-start gap-3 text-sm">
              <span class="text-[color:var(--color-cyan)]">+</span>
              <span class="text-[color:var(--color-text)]">Brand identity</span>
            </li>
            <li class="flex items-start gap-3 text-sm">
              <span class="text-[color:var(--color-cyan)]">+</span>
              <span class="text-[color:var(--color-text)]">3-month consulting retainer</span>
            </li>
          </ul>
          <div class="bg-white/5 p-4 rounded-lg">
            <p class="text-sm text-[color:var(--color-muted)] mb-1">Example:</p>
            <p class="text-sm">Business Site + Core Brand + 3-Month Retainer = <span class="line-through opacity-60">$5,900</span> → <span class="text-[color:var(--color-cyan)] font-bold text-lg">$4,720</span></p>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- SUPPLEMENTAL SERVICES -->
  {supplementalServices.length > 0 && (
    <section class="relative py-16 md:py-24">
      <div class="max-w-7xl mx-auto px-5 md:px-8">
        <SectionHeading
          eyebrow="Additional Services"
          title="We also offer"
        />

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mt-14">
          {supplementalServices.map((s) => (
            <Card class="group">
              <div class="flex items-start gap-5">
                <div class={`h-12 w-12 flex-shrink-0 rounded-2xl border border-white/10 bg-gradient-to-br ${accentGlow[s.accent]} flex items-center justify-center text-white`}>
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6" set:html={s.iconSvg}></svg>
                </div>
                <div class="flex-1">
                  <h3 class="text-lg font-semibold text-white leading-tight">{s.title}</h3>
                  <p class={`mt-1 text-sm ${accentText[s.accent]}`}>{s.tagline}</p>
                </div>
              </div>
              <p class="mt-4 text-[color:var(--color-muted)] leading-relaxed text-sm">{s.description}</p>
            </Card>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- PROCESS -->
  <section class="relative py-20 md:py-28 bg-white/[0.02]">
    <div class="max-w-7xl mx-auto px-5 md:px-8">
      <SectionHeading
        eyebrow="How we work"
        title="Four steps. No mystery."
      />

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mt-14">
        {process.map((p) => (
          <Card>
            <p class="text-4xl font-bold nnt-gradient-text-warm leading-none">{p.step}</p>
            <h3 class="mt-5 text-lg font-semibold text-white">{p.title}</h3>
            <p class="mt-2 text-[color:var(--color-muted)] leading-relaxed text-sm">{p.body}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY NOVA NEXUS -->
  <section class="relative py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-5 md:px-8">
      <SectionHeading
        title="Why Nova Nexus Texas?"
      />

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mt-14">
        <div class="text-center">
          <div class="text-4xl mb-4">⚡</div>
          <h3 class="text-xl font-semibold text-white mb-3">Faster Builds</h3>
          <p class="text-[color:var(--color-muted)] leading-relaxed">AI-accelerated development means we ship websites in weeks, not months — without cutting corners.</p>
        </div>

        <div class="text-center">
          <div class="text-4xl mb-4">💰</div>
          <h3 class="text-xl font-semibold text-white mb-3">Honest Pricing</h3>
          <p class="text-[color:var(--color-muted)] leading-relaxed">You see the number before you sign. No surprise line items. No hidden fees. Ever.</p>
        </div>

        <div class="text-center">
          <div class="text-4xl mb-4">📞</div>
          <h3 class="text-xl font-semibold text-white mb-3">Real Accountability</h3>
          <p class="text-[color:var(--color-muted)] leading-relaxed">One founder. One phone number. You call, Lupe answers. No outsourced support ticket hell.</p>
        </div>

        <div class="text-center">
          <div class="text-4xl mb-4">🏘️</div>
          <h3 class="text-xl font-semibold text-white mb-3">Community First</h3>
          <p class="text-[color:var(--color-muted)] leading-relaxed">We live here. Your customers are our neighbors. We market like it.</p>
        </div>

        <div class="text-center">
          <div class="text-4xl mb-4">🎯</div>
          <h3 class="text-xl font-semibold text-white mb-3">20 Years Experience</h3>
          <p class="text-[color:var(--color-muted)] leading-relaxed">Two decades building brands and shipping software. This isn't our first rodeo — it's our best one yet.</p>
        </div>

        <div class="text-center">
          <div class="text-4xl mb-4">🤖</div>
          <h3 class="text-xl font-semibold text-white mb-3">AI-Powered Edge</h3>
          <p class="text-[color:var(--color-muted)] leading-relaxed">We use AI to move fast on the busy work so we can spend real time on what matters: your success.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 md:py-28">
    <div class="max-w-4xl mx-auto px-5 md:px-8 text-center">
      <h2 class="text-4xl md:text-5xl font-bold text-white">Let's build something worth finding.</h2>
      <p class="mt-5 text-lg text-[color:var(--color-muted)]">
        Free 30-minute discovery call. No pressure, no commitment — just a real conversation about your business.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row justify-center gap-4">
        <Button href="/contact" variant="primary">Book Free Discovery</Button>
        <Button href="/pricing" variant="secondary">See Full Pricing</Button>
      </div>
    </div>
  </section>
</BaseLayout>
