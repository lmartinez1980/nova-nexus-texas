---
import BaseLayout from "../components/BaseLayout.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";
import SectionHeading from "../components/SectionHeading.astro";

const roles = [
  {
    title: "Photographers",
    body: "Capture brand stories, event coverage, product shots — help local businesses look their best.",
    icon: `<rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>`,
  },
  {
    title: "Videographers",
    body: "Shoot testimonials, highlight reels, social content, and event videos that bring brands to life.",
    icon: `<path d="m22 8-6 4 6 4V8Z"/><rect width="14" height="12" x="2" y="6" rx="2" ry="2"/>`,
  },
  {
    title: "Social Media Managers",
    body: "Write captions, schedule posts, engage audiences — be the voice behind local brands online.",
    icon: `<path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/>`,
  },
  {
    title: "Models",
    body: "Represent brands in photo/video shoots, product launches, and promotional campaigns.",
    icon: `<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>`,
  },
  {
    title: "Actors / Voice Talent",
    body: "Bring scripts to life — commercials, explainer videos, audio ads, and promotional content.",
    icon: `<path d="M11 5 6 9H2v6h4l5 4V5z"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>`,
  },
  {
    title: "Event Hosts / MCs",
    body: "Run the show — emcee launches, grand openings, community events, and brand activations.",
    icon: `<path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/>`,
  },
];

const perks = [
  "💰 Competitive gig pay — fair rates, paid promptly",
  "📅 Flexible schedule — work when you're available",
  "🎯 Real clients, real work — no spec projects or 'exposure'",
  "🤝 Local community focus — DFW businesses you can actually visit",
  "🚀 Grow with us — recurring gigs for reliable talent",
];
---
<BaseLayout
  title="Work With Us — Gig Opportunities in Arlington, TX | Nova Nexus Texas"
  description="Join the Nova Nexus Texas crew. Flexible gig work for photographers, videographers, social media pros, models, actors, and event hosts in the DFW area."
>
  <!-- HERO -->
  <section class="relative pt-20 md:pt-28 pb-16 md:pb-20">
    <div class="max-w-5xl mx-auto px-5 md:px-8 text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-1.5 text-xs font-medium uppercase tracking-[0.18em] text-[color:var(--color-muted)] backdrop-blur-md">
        <span class="h-1.5 w-1.5 rounded-full bg-[color:var(--color-cyan)] shadow-[0_0_12px_#00D9FF]"></span>
        Now Hiring · Arlington & DFW
      </div>

      <h1 class="mt-8 text-5xl md:text-7xl font-bold text-white leading-[1.05] tracking-tight">
        Join the <span class="nnt-gradient-text">Nova Nexus crew.</span>
      </h1>

      <p class="mt-6 mx-auto max-w-2xl text-lg md:text-xl text-[color:var(--color-muted)] leading-relaxed">
        Flexible gig work helping real local businesses shine. Get paid to do what you do best — on your schedule, in your community.
      </p>

      <div class="mt-10">
        <Button href="#apply" variant="primary">
          Apply Now
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </Button>
      </div>
    </div>
  </section>

  <!-- ROLES -->
  <section class="relative py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-5 md:px-8">
      <SectionHeading
        eyebrow="Who we're looking for"
        title="Roles we hire for"
        subtitle="Project-based gig work. No full-time commitment. Just show up, do great work, get paid."
      />
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mt-14">
        {roles.map((role) => (
          <Card>
            <div class="h-11 w-11 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-[color:var(--color-cyan)]">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5" set:html={role.icon}></svg>
            </div>
            <h3 class="mt-5 text-xl font-semibold text-white">{role.title}</h3>
            <p class="mt-3 text-[color:var(--color-muted)] leading-relaxed">{role.body}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="relative py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-5 md:px-8">
      <SectionHeading
        eyebrow="How it works"
        title="Simple. Flexible. Fair."
      />
      <div class="grid md:grid-cols-3 gap-8 mt-14">
        <div class="text-center">
          <div class="inline-flex h-14 w-14 items-center justify-center rounded-full bg-gradient-to-br from-[color:var(--color-cyan)] to-[color:var(--color-violet)] text-black font-bold text-xl">1</div>
          <h3 class="mt-5 text-lg font-semibold text-white">You apply</h3>
          <p class="mt-2 text-[color:var(--color-muted)] leading-relaxed">Fill out the form below. Tell us what you do and when you're available.</p>
        </div>
        <div class="text-center">
          <div class="inline-flex h-14 w-14 items-center justify-center rounded-full bg-gradient-to-br from-[color:var(--color-violet)] to-[color:var(--color-magenta)] text-black font-bold text-xl">2</div>
          <h3 class="mt-5 text-lg font-semibold text-white">We reach out</h3>
          <p class="mt-2 text-[color:var(--color-muted)] leading-relaxed">When a gig matches your skills, we'll contact you with details and timeline.</p>
        </div>
        <div class="text-center">
          <div class="inline-flex h-14 w-14 items-center justify-center rounded-full bg-gradient-to-br from-[color:var(--color-magenta)] to-[color:var(--color-amber)] text-black font-bold text-xl">3</div>
          <h3 class="mt-5 text-lg font-semibold text-white">You get paid</h3>
          <p class="mt-2 text-[color:var(--color-muted)] leading-relaxed">Do the work, get paid promptly. No chasing invoices. No 'exposure' nonsense.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PERKS -->
  <section class="relative py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-5 md:px-8">
      <Card class="!p-10 md:!p-12">
        <h2 class="text-2xl md:text-3xl font-bold text-white text-center">Why work with Nova Nexus?</h2>
        <ul class="mt-8 space-y-4">
          {perks.map((perk) => (
            <li class="flex items-start gap-3 text-lg text-[color:var(--color-text)]">
              <span class="text-2xl leading-none">{perk.split(' ')[0]}</span>
              <span>{perk.substring(perk.indexOf(' ') + 1)}</span>
            </li>
          ))}
        </ul>
      </Card>
    </div>
  </section>

  <!-- APPLICATION FORM -->
  <section id="apply" class="relative py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-5 md:px-8">
      <SectionHeading
        title="Ready to join?"
        subtitle="Fill out the form below and we'll be in touch when opportunities match your skills."
      />

      <Card class="mt-12 !p-8 md:!p-10">
        <form action="mailto:lupe@novanexustexas.com" method="POST" enctype="text/plain" class="space-y-6">
          <!-- Name -->
          <div>
            <label for="name" class="block text-sm font-medium text-white mb-2">Full Name *</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder:text-[color:var(--color-muted)] focus:outline-none focus:ring-2 focus:ring-[color:var(--color-cyan)] focus:border-transparent"
              placeholder="Your name"
            />
          </div>

          <!-- Email -->
          <div>
            <label for="email" class="block text-sm font-medium text-white mb-2">Email *</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder:text-[color:var(--color-muted)] focus:outline-none focus:ring-2 focus:ring-[color:var(--color-cyan)] focus:border-transparent"
              placeholder="you@example.com"
            />
          </div>

          <!-- Phone -->
          <div>
            <label for="phone" class="block text-sm font-medium text-white mb-2">Phone</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder:text-[color:var(--color-muted)] focus:outline-none focus:ring-2 focus:ring-[color:var(--color-cyan)] focus:border-transparent"
              placeholder="(555) 123-4567"
            />
          </div>

          <!-- Role(s) -->
          <div>
            <label for="roles" class="block text-sm font-medium text-white mb-2">What role(s) are you interested in? *</label>
            <select
              id="roles"
              name="roles"
              required
              multiple
              size="6"
              class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white focus:outline-none focus:ring-2 focus:ring-[color:var(--color-cyan)] focus:border-transparent appearance-none"
              style="color: black; background-color: white;"
            >
              <option value="photographer">Photographer</option>
              <option value="videographer">Videographer</option>
              <option value="social-media">Social Media Manager</option>
              <option value="model">Model</option>
              <option value="actor-voice">Actor / Voice Talent</option>
              <option value="event-host">Event Host / MC</option>
            </select>
            <p class="mt-2 text-xs text-[color:var(--color-muted)]">Hold Ctrl (Windows) or Cmd (Mac) to select multiple</p>
          </div>

          <!-- Experience -->
          <div>
            <label for="experience" class="block text-sm font-medium text-white mb-2">Tell us about your experience *</label>
            <textarea
              id="experience"
              name="experience"
              required
              rows="5"
              class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder:text-[color:var(--color-muted)] focus:outline-none focus:ring-2 focus:ring-[color:var(--color-cyan)] focus:border-transparent resize-none"
              placeholder="Share your background, past gigs, portfolio links, or anything that shows what you bring to the table..."
            ></textarea>
          </div>

          <!-- Availability -->
          <div>
            <label for="availability" class="block text-sm font-medium text-white mb-2">Availability</label>
            <input
              type="text"
              id="availability"
              name="availability"
              class="w-full px-4 py-3 rounded-lg bg-white/5 border border-white/10 text-white placeholder:text-[color:var(--color-muted)] focus:outline-none focus:ring-2 focus:ring-[color:var(--color-cyan)] focus:border-transparent"
              placeholder="e.g., Weekends only, flexible weekdays, evenings after 5pm..."
            />
          </div>

          <!-- Submit -->
          <div class="pt-4">
            <button
              type="submit"
              class="w-full px-6 py-4 rounded-lg bg-gradient-to-r from-[color:var(--color-cyan)] to-[color:var(--color-violet)] text-black font-semibold hover:shadow-[0_0_30px_rgba(0,217,255,0.5)] transition-all duration-300"
            >
              Submit Application
            </button>
          </div>
        </form>
      </Card>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 md:py-28">
    <div class="max-w-3xl mx-auto px-5 md:px-8 text-center">
      <h2 class="text-3xl md:text-5xl font-bold text-white">Questions?</h2>
      <p class="mt-5 text-lg text-[color:var(--color-muted)]">
        Reach out anytime. We're building this thing together.
      </p>
      <div class="mt-8">
        <Button href="/contact" variant="secondary">Get In Touch</Button>
      </div>
    </div>
  </section>
</BaseLayout>
